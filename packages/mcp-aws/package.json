	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./dynamo": {
			"types": "./dist/session/dynamo.d.ts",
			"import": "./dist/session/dynamo.js"
		},
