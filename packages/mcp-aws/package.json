		"@aws-sdk/lib-dynamodb": "^3.0.0",
		"@aws-sdk/client-dynamodb": "^3.0.0",
		"@aws-sdk/client-lambda": "^3.0.0",
		"@aws-sdk/client-iam": "^3.0.0",
		"@aws-sdk/client-sts": "^3.0.0"
	},
	"devDependencies": {
		"@playwright/mcp": "^0.0.68",
		"@types/aws-lambda": "^8.10.0",
		"@types/express": "^5.0.0",
		"express": "^5.1.0",
		"stratus-sdk": "workspace:*",
